# Chave do Google AI Studio (https://aistudio.google.com/apikey)
# Sem a chave, o app roda em modo mock (motor de recomendação local, ótimo pra iterar UI)
GEMINI_API_KEY=

# Modelo do Gemini (opcional; o alias -latest acompanha o flash mais recente)
GEMINI_MODEL=gemini-flash-latest

# Chave da Steam Web API (https://steamcommunity.com/dev/apikey)
# O pipeline atual (SteamSpy + appdetails) não precisa dela; guarda pra
# endpoints futuros (ex: reviews detalhadas)
STEAM_API_KEY=
